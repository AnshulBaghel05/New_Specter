# ──────────────────────────────────────────────────────────────────────────────
# SPECTER SCRAPER (Node.js / BullMQ) — environment configuration
#
# Copy to `.env` and fill in real values. Never commit `.env`.
#   cp .env.example .env
#
# Required to run the workers: UPSTASH_REDIS_URL (the job queue) and
# SPECTER_API_URL (where parse results are POSTed back). Proxies/CAPTCHA are
# optional and only needed for bot-protected targets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Redis (BullMQ job queue) ──────────────────────────────────────────────────
# MUST be the SAME Redis instance the API enqueues to (specter-api UPSTASH_REDIS_URL).
# ioredis-compatible URL; use rediss:// for TLS (Upstash).
# Local:  redis://localhost:6379
# Upstash: rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379
UPSTASH_REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379

# Optional split (production hardening). The BullMQ broker (durable jobs) and the
# ephemeral state store (rate-limit/locks/cycle counters/proxy health) can run on
# separate instances so state churn never evicts queued jobs. Both default to
# UPSTASH_REDIS_URL when unset, so local dev needs neither.
# BROKER_REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_BROKER_HOST.upstash.io:6379
# STATE_REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_STATE_HOST.upstash.io:6379

# ── specter-api callback ──────────────────────────────────────────────────────
# Internal base URL workers POST parse results / blocked-domain events to.
# Defaults to http://localhost:8000 if unset.
SPECTER_API_URL=http://localhost:8000

# Shared HMAC secret for signing those callbacks (lib/ingest-client.ts). MUST be
# byte-identical to the API service's SCRAPER_INGEST_SECRET — a mismatch means
# every result POST is rejected 401 and no prices ingest. Required in production.
SCRAPER_INGEST_SECRET=YOUR_SCRAPER_INGEST_SECRET

# ── Proxies (optional — anti-bot) ─────────────────────────────────────────────
# Datacenter proxy for cheap HTTP/probe scrapes (http.ts, probe.ts).
# Residential proxy for Playwright/stealth scrapes of protected sites (playwright.ts).
# Leave blank to scrape directly with no proxy.
# Format: http://USER:PASSWORD@PROXY_HOST:PORT
PROXY_DATACENTER_URL=
PROXY_RESIDENTIAL_URL=

# ── CAPTCHA solving (optional) ────────────────────────────────────────────────
# 2Captcha API key used by the dedicated captcha-solver worker (captcha-solver.ts)
# to solve challenges on bot-walled targets. Leave blank to skip CAPTCHA solving.
TWOCAPTCHA_API_KEY=

# ── Shared browser farm (optional — scale) ────────────────────────────────────
# When set, the Playwright worker connects to a shared Chromium pool over CDP
# (e.g. browserless or a self-hosted chrome farm) instead of launching its own
# per-process browser, so browser capacity scales independently of workers.
# Egress proxy must be configured on the farm endpoint in this mode.
# Leave blank to launch a local Chromium per worker process.
# Format: ws://HOST:PORT  or  wss://chrome.browserless.io?token=...
BROWSER_WS_ENDPOINT=

# ── Bull Board ops dashboard (runs as its own Railway service) ────────────────
# HTTP Basic Auth for /ops/queues (bull-board.ts). BOTH must be set or the board
# refuses to serve (fails closed with 500). Pick a strong password.
BULL_BOARD_USER=ops
BULL_BOARD_PASS=YOUR_STRONG_PASSWORD
# Port the Bull Board Express server binds. Railway injects $PORT; this overrides.
# BULL_BOARD_PORT=3001
