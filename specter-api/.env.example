# ──────────────────────────────────────────────────────────────────────────────
# SPECTER API (FastAPI) — environment configuration
#
# Copy to `.env` and fill in real values. Never commit `.env`.
#   cp .env.example .env
#
# Required to boot the server: DATABASE_URL, UPSTASH_REDIS_URL, SUPABASE_JWT_SECRET.
# The rest unlock specific features (Shopify OAuth, AI signals, email, billing).
# ──────────────────────────────────────────────────────────────────────────────

# ── Core: Database (Postgres) ─────────────────────────────────────────────────
# SQLAlchemy async URL — MUST use the asyncpg driver (postgresql+asyncpg://).
# The same URL drives Alembic migrations (alembic/env.py).
# Local:  postgresql+asyncpg://specter:specter@localhost:5432/specter
# Hosted: a Supabase / Neon / Railway Postgres connection string.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/specter

# ── Core: Redis (BullMQ queue bridge) ─────────────────────────────────────────
# Used by queue_client.py to enqueue scrape jobs the Node scraper consumes.
# Use rediss:// (TLS) for Upstash; redis:// for a local instance.
# Local:  redis://localhost:6379
# Upstash: rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379
UPSTASH_REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379

# ── Core: Auth (Supabase JWT) ─────────────────────────────────────────────────
# Validates the bearer token on every request.
# Supabase Dashboard → Project Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET

# ── Secrets at rest (Fernet) ──────────────────────────────────────────────────
# URL-safe base64-encoded 32-byte key used to encrypt stored Shopify tokens.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=YOUR_FERNET_KEY_44_CHARS_BASE64_URLSAFE=

# ── Shopify OAuth (store connect / repricing write-back) ──────────────────────
# Shopify Partners → your app → API credentials. The redirect URI must match the
# app's allowed callback exactly.
SHOPIFY_API_KEY=YOUR_SHOPIFY_API_KEY
SHOPIFY_API_SECRET=YOUR_SHOPIFY_API_SECRET
SHOPIFY_REDIRECT_URI=http://localhost:8000/merchants/shopify/callback
SHOPIFY_SCOPES=read_products,write_products
# Where the API redirects the merchant after a completed OAuth flow.
DASHBOARD_URL=http://localhost:3000/dashboard

# ── AI signals (Google Gemini) ────────────────────────────────────────────────
# Powers RAISE/LOWER/HOLD reasoning (signals/ai_engine.py). Without it, signals
# fall back to the deterministic rule engine.
# Google AI Studio → Get API key.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ── Transactional email (Resend) ──────────────────────────────────────────────
# OOS alerts, scrape-failure notices, trial reminders, ECLIPSE fallback notices.
# Best-effort: if RESEND_API_KEY is unset, emails are skipped (never blocks).
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM=SPECTER <alerts@specterapp.io>

# ── Billing (Razorpay) ────────────────────────────────────────────────────────
# Razorpay Dashboard → Settings → API Keys (key id + secret) and Webhooks (secret).
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=YOUR_RAZORPAY_WEBHOOK_SECRET

# Subscription plan IDs (Razorpay Dashboard → Subscriptions → Plans).
# One id per plan × cadence. ECLIPSE is sales-led — no self-serve plan id.
RAZORPAY_PLAN_RECON_MONTHLY=plan_YOUR_RECON_MONTHLY
RAZORPAY_PLAN_RECON_ANNUAL=plan_YOUR_RECON_ANNUAL
RAZORPAY_PLAN_CIPHER_MONTHLY=plan_YOUR_CIPHER_MONTHLY
RAZORPAY_PLAN_CIPHER_ANNUAL=plan_YOUR_CIPHER_ANNUAL
RAZORPAY_PLAN_PHANTOM_MONTHLY=plan_YOUR_PHANTOM_MONTHLY
RAZORPAY_PLAN_PHANTOM_ANNUAL=plan_YOUR_PHANTOM_ANNUAL
RAZORPAY_PLAN_PREDATOR_MONTHLY=plan_YOUR_PREDATOR_MONTHLY
RAZORPAY_PLAN_PREDATOR_ANNUAL=plan_YOUR_PREDATOR_ANNUAL

# À-la-carte add-on plan IDs (PRICING.md — À La Carte).
RAZORPAY_PLAN_ADDON_50SKU=plan_YOUR_ADDON_50SKU
RAZORPAY_PLAN_ADDON_100SKU=plan_YOUR_ADDON_100SKU
RAZORPAY_PLAN_ADDON_SPEED_RECON=plan_YOUR_ADDON_SPEED_RECON
RAZORPAY_PLAN_ADDON_SPEED_CIPHER=plan_YOUR_ADDON_SPEED_CIPHER
RAZORPAY_PLAN_ADDON_SPEED_PHANTOM=plan_YOUR_ADDON_SPEED_PHANTOM

# ── Scheduled jobs (cron) ─────────────────────────────────────────────────────
# Bearer secret the daily trial-monitor cron sends to POST /internal/run-trial-
# monitor (downgrades lapsed RECON trials + sends day-12/14 reminder emails).
# Required for trials to expire — see CRON.md. Use the SAME value on the API and
# the cron service. Fails closed: unset ⇒ the endpoint returns 500.
TRIAL_MONITOR_SECRET=YOUR_TRIAL_MONITOR_SECRET

# ── Enterprise: ECLIPSE dedicated worker (F10) ────────────────────────────────
# Base URL of the merchant's dedicated scrape worker. On 503/timeout the API
# re-queues onto shared capacity (workers/eclipse_router.py). Optional.
ECLIPSE_WORKER_URL=https://eclipse-worker.YOUR_HOST.internal/scrape

# ── Proxy pools (Audit #3) ────────────────────────────────────────────────────
# Each tier accepts a comma-list of endpoints OR a single rotating-gateway URL.
# The plural list var wins over the singular fallback. Omit both → no-proxy mode
# (direct fetch; intended for local dev/preview only). Datacenter is the default
# workhorse (~70-80% HTTP); residential is the JS/Playwright backup + failover tier.
PROXY_DATACENTER_URLS=
PROXY_RESIDENTIAL_URLS=
# Backward-compatible singular fallbacks:
# PROXY_DATACENTER_URL=
# PROXY_RESIDENTIAL_URL=
# Origin-IP safety: when proxies ARE configured but the pool is fully cooling,
# the default REQUEUES the job rather than exposing the origin IP. Set true ONLY
# in dev/preview to allow a direct fetch in that exhausted-pool case.
ALLOW_DIRECT_FALLBACK=false
# Optional tunables:
# PROXY_COOLDOWN_MS=300000
# PROXY_STICKY_WINDOW_MS=30000
# PROXY_REQUEUE_DELAY_MS=60000

# ── Cost ledger & margin reporting (Audit #4) ─────────────────────────────────
# Operator-only key guarding GET /admin/cost/margin (sent as the X-Admin-Key
# header, constant-time compared). The endpoint FAILS CLOSED (500) when unset, so
# cost data is never served without a key. Generate any high-entropy secret:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=YOUR_ADMIN_API_KEY
# Unit cost rates — override only when vendor pricing moves; defaults track
# COST_ANALYSIS.md. Bandwidth is billed per decimal GB (1e9 bytes).
# COST_RATE_RESIDENTIAL_USD_PER_GB=8.40
# COST_RATE_DATACENTER_USD_PER_GB=0.30
# COST_RATE_CAPTCHA_USD_PER_SOLVE=0.002
# COST_RATE_AI_PRO_IN_PER_1M=1.25
# COST_RATE_AI_PRO_OUT_PER_1M=5.00
# COST_RATE_AI_FLASH_IN_PER_1M=0.075
# COST_RATE_AI_FLASH_OUT_PER_1M=0.30

# ── Observability (Sentry) ────────────────────────────────────────────────────
# Sentry DSN for the API (Sentry → Project → Settings → Client Keys). When unset,
# error tracking is a complete no-op (see observability.py) — dev/test need none.
SENTRY_DSN=
# Optional override for the environment tag (defaults to RAILWAY_ENVIRONMENT or
# "production"). Tracing is off by default; set a rate to sample transactions.
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.0
