# ──────────────────────────────────────────────────────────────────────────────
# SPECTER WEB (Next.js) — environment configuration
#
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
#   cp .env.example .env.local
#
# NEXT_PUBLIC_* vars are exposed to the browser — never put secrets there.
# For a backend-free local demo, set NEXT_PUBLIC_PREVIEW=1 and leave the rest blank.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (auth) ───────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API.
# Required for real sign-in / sign-up and the /dashboard middleware guard.
# Leave blank when running in preview mode (NEXT_PUBLIC_PREVIEW=1).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Server-only admin key (service_role) — NEVER expose to the browser. Optional;
# only needed for privileged server-side Supabase operations.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Backend API (specter-api) ─────────────────────────────────────────────────
# Base URL the dashboard + calculations client call. In preview mode the app
# serves fixtures and never hits this.
# Local:  http://localhost:8000
# Hosted: https://specter-api.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Analytics (PostHog) ───────────────────────────────────────────────────────
# Optional. If unset, analytics is silently disabled. Host is app.posthog.com.
NEXT_PUBLIC_POSTHOG_KEY=phc_YOUR_POSTHOG_PROJECT_KEY

# ── Email capture (Resend) — server-side API route ────────────────────────────
# Used by app/api/email-capture/route.ts to add leads to a Resend audience.
# Server-only (no NEXT_PUBLIC_ prefix). Optional.
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_AUDIENCE_ID=YOUR_RESEND_AUDIENCE_ID

# ── Billing (Razorpay) ────────────────────────────────────────────────────────
# Razorpay PUBLISHABLE key id (same value as specter-api's RAZORPAY_KEY_ID).
# Safe to expose — it only identifies the account to the embedded checkout.js
# modal; the key SECRET and webhook secret live server-side in specter-api only.
# When unset, checkout falls back to the hosted short_url instead of the modal.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ── Observability (Sentry) ────────────────────────────────────────────────────
# Public DSN for browser + server error tracking (Sentry → Project → Client Keys).
# NEXT_PUBLIC_ so the client can report. When unset, Sentry is a no-op and the
# build is unaffected. Errors are only sent in production (NODE_ENV check).
NEXT_PUBLIC_SENTRY_DSN=
# Build-time source-map upload (CI/Vercel only). All three must be set for upload;
# without them the build still succeeds, just without readable stack traces.
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ── Local preview (dev only) ──────────────────────────────────────────────────
# When =1, the dashboard renders fully from fixtures with no backend/auth — the
# zero-setup way to explore every feature locally. Leave unset/0 in production.
NEXT_PUBLIC_PREVIEW=1
